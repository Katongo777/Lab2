modules = ["bash", "nix"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc -o test test.c -lm 2>&1 && echo '=== Compiled OK ===' && ./test || gcc main.c list.c -o main 2>&1 && echo '=== main compiled ==='"

[workflows.workflow.metadata]
outputType = "console"
